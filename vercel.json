{
  "version": 2,
  "buildCommand": "composer install --no-dev --optimize-autoloader && php vercel/build.php",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2",
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "^/(.+\\.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|map|txt|xml|pdf|zip)$)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "DB_HOST": "REPLACE_WITH_DEMO_DB_HOST",
    "DB_PORT": "3306",
    "DB_NAME": "gcm_demo",
    "DB_USER": "gcm_demo",
    "DB_PASS": "GcmDemo@2024"
  }
}
