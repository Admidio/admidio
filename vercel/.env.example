# Vercel Environment Variables — Ghana Council e.V.
# Copy these into Vercel Dashboard → Project Settings → Environment Variables
# NEVER commit a file containing real credentials to git.

# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=your-database-host.example.com
DB_PORT=3306
DB_NAME=gcm
DB_USER=gcm_user
DB_PASS=change-me-to-a-strong-password

# ── Notes ───────────────────────────────────────────────────────────────────
# Root URL and timezone are hard-coded in vercel/build.php:
#   g_root_path  = https://www.ghanacouncil-nrw.de
#   gTimezone    = Europe/Berlin
#
# Recommended database providers (compatible with Vercel):
#   PlanetScale  https://planetscale.com   (MySQL-compatible, free tier)
#   Railway      https://railway.app        (MySQL/MariaDB, easy setup)
#   Aiven        https://aiven.io           (MySQL, EU-hosted options)
